# ClickHouse demo-DM (docker stand; runs on Mac, see docs/PLAN.md 0.2)
AUTO_BI_CH_HOST=localhost
AUTO_BI_CH_PORT=8123
AUTO_BI_CH_USER=auto_bi_ro
AUTO_BI_CH_PASSWORD=change_me
AUTO_BI_CH_DATABASE=dm
# CH address as seen from the BI server when it differs (compose network / SSH tunnel)
AUTO_BI_CH_HOST_FROM_BI=clickhouse
AUTO_BI_CH_PORT_FROM_BI=8123

# Greenplum / Greengage DWH (v2 engine, read-only role — optional, only if you introspect
# or advise against a GP/Greengage warehouse)
AUTO_BI_GP_HOST=localhost
AUTO_BI_GP_PORT=5432
AUTO_BI_GP_USER=auto_bi_ro
AUTO_BI_GP_PASSWORD=change_me
AUTO_BI_GP_DATABASE=postgres
AUTO_BI_GP_SCHEMA=dm

# Superset (docker stand)
AUTO_BI_SUPERSET_URL=http://localhost:8088
AUTO_BI_SUPERSET_USER=admin
AUTO_BI_SUPERSET_PASSWORD=change_me

# DataLens — self-hosted OSS stand (v2 BI target, optional — only if target_bi=datalens)
AUTO_BI_DATALENS_URL=http://localhost:8090
AUTO_BI_DATALENS_USER=admin
AUTO_BI_DATALENS_PASSWORD=admin
# Dedicated "Auto_BI" workbook on the stand (Phase 4 F3 — keeps idempotent rebuilds from
# ever touching foreign entries). Stand-specific id, not a secret.
AUTO_BI_DATALENS_WORKBOOK_ID=change_me
# ClickHouse host as the DataLens connection reaches it (e.g. host.docker.internal on a
# self-hosted compose stand); port reuses AUTO_BI_CH_PORT.
AUTO_BI_CH_HOST_FROM_DATALENS=host.docker.internal

# LLM provider (default: anthropic — direct Messages API, just needs a key)
AUTO_BI_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=change_me
AUTO_BI_ANTHROPIC_MODEL=claude-sonnet-4-6
AUTO_BI_ANTHROPIC_MAX_TOKENS=16000

# GraceKelly LLM service (local, opt-in alternative: AUTO_BI_LLM_PROVIDER=gracekelly)
AUTO_BI_GRACEKELLY_URL=http://127.0.0.1:8011
AUTO_BI_GRACEKELLY_MODEL=claude-sonnet-5

# Send row samples of low-cardinality columns to LLM (see ARCHITECTURE §4)
AUTO_BI_SEND_SAMPLES=true

# SQLite store (sessions, specs, builds, llm_calls, dm_change_requests, users)
AUTO_BI_STORE_PATH=data/auto_bi.sqlite

# Auth + RBAC (Phase 4) — OPT-IN, off by default; single-user use needs none of this
# (see USER_GUIDE §7). When enabled, restricts each user to their allowed DWH schemas.
AUTO_BI_AUTH_ENABLED=false
# YAML of users: `users: [{username, password, role, schemas: [...]}]` (plaintext
# passwords hashed before reaching the store — keep this file out of VCS).
AUTO_BI_AUTH_USERS_FILE=
# Bootstrap admin, used only when auth is on AND no users file is given.
AUTO_BI_ADMIN_USER=admin
AUTO_BI_ADMIN_PASSWORD=change_me
AUTO_BI_AUTH_TOKEN_TTL_HOURS=24
# `Secure` flag on the login cookie: unset (default) = auto — on unless bound to a
# loopback host (see USER_GUIDE §7). Uncomment to force it regardless of --host.
# AUTO_BI_AUTH_COOKIE_SECURE=true

# LLM-call quota on session endpoints (O-2) — OPT-IN, off by default; local/dev use
# needs none of this (see USER_GUIDE §7). Protects the LLM budget from runaway per-IP
# usage before a public/demo deployment: gates POST /api/v1/sessions and
# /sessions/{id}/reply, per IP, per rolling day.
AUTO_BI_SESSION_RATE_ENABLED=false
AUTO_BI_SESSION_RATE_PER_DAY=100
# Expensive non-LLM work quota (P0-3): auto start / approve / insights. OPT-IN;
# forced ON when DEMO_AUTO_ONLY is true. Separate from the LLM session quota above.
AUTO_BI_WORK_RATE_ENABLED=false
AUTO_BI_WORK_RATE_PER_DAY=50
# Hard cap on concurrent builds in one process (P0-3). Approve → 503 when full.
AUTO_BI_MAX_CONCURRENT_BUILDS=2
# LLM client-seam budget (P0-3 item 4) — OPT-IN, off by default. The quotas above gate
# REQUESTS; this caps actual provider round-trips (grounding + propose + advisor + up to
# 3 repair retries), enforced in the repair loop so the initial call AND every repair
# draw it down. Scoped per session and per actor / rolling 24h (one global bucket when
# auth is off). A limit of 0 / 0.0 = that dimension is unlimited. See DEPLOYMENT §3.
AUTO_BI_LLM_BUDGET_ENABLED=false
# per conversation (session)
AUTO_BI_LLM_BUDGET_SESSION_MAX_CALLS=0
AUTO_BI_LLM_BUDGET_SESSION_MAX_TOKENS=0
AUTO_BI_LLM_BUDGET_SESSION_MAX_SECONDS=0
AUTO_BI_LLM_BUDGET_SESSION_MAX_COST_USD=0
# per actor (session owner; global bucket when auth off) / rolling 24h
AUTO_BI_LLM_BUDGET_DAY_MAX_CALLS=0
AUTO_BI_LLM_BUDGET_DAY_MAX_TOKENS=0
AUTO_BI_LLM_BUDGET_DAY_MAX_SECONDS=0
AUTO_BI_LLM_BUDGET_DAY_MAX_COST_USD=0
# cost price table, USD per 1000 tokens, "model:in/out,..." (example rates — set yours;
# used only when a *_MAX_COST_USD limit above is set)
AUTO_BI_LLM_BUDGET_PRICES=claude-sonnet-4-6:0.003/0.015,claude-sonnet-5:0.003/0.015
# Fail-closed remote bind (P0-3): required to serve on non-loopback with auth off
# and without DEMO_AUTO_ONLY. Prefer AUTH_ENABLED=true on the public internet.
AUTO_BI_ALLOW_INSECURE_REMOTE=false
# F-2: which peers may set X-Forwarded-For (real client IPs for the per-IP quotas
# behind a reverse proxy). Unset = trust loopback only (same-host proxy). For a
# containerized proxy set the proxy address(es), or "*" ONLY when the app port is
# reachable exclusively from the proxy (compose internal network) — see DEPLOYMENT §3.
# AUTO_BI_FORWARDED_ALLOW_IPS=*

# Public demo mode (P8): auto-overview is the only open path — text/fields/word edits
# (LLM) and enrichment writes answer 403, no LLM provider/key is needed at all.
# AUTO_BI_DEMO_AUTO_ONLY=true
# Public base for dashboard LINKS when it differs from the Superset URL the adapter
# calls (demo: adapter -> 127.0.0.1:8088 in-container, viewer -> https://<host>).
# AUTO_BI_SUPERSET_PUBLIC_URL=https://demo.example.com
